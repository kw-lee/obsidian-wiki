# ── Database ──────────────────────────────────────────
POSTGRES_USER=obsidian
POSTGRES_PASSWORD=changeme
POSTGRES_DB=obsidian_wiki
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Runtime mode / CORS ───────────────────────────────
APP_ENV=development
# In production, set the exact allowed browser origins as a comma-separated list.
# Example: CORS_ALLOWED_ORIGINS=https://wiki.example.com,https://notes.example.com
CORS_ALLOWED_ORIGINS=

# ── Auth ──────────────────────────────────────────────
# 32+ chars. Example: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand
INIT_ADMIN_USERNAME=admin
# Change this before production. Minimum 12 characters recommended.
INIT_ADMIN_PASSWORD=changeme
APP_TIMEZONE=Asia/Seoul

# ── Runtime Settings ──────────────────────────────────
# Runtime-mutable sync settings are managed from the /settings web UI.
# These optional values are only used once to seed the initial sync settings row.
# GIT_REMOTE_URL=git@github.com:user/vault.git
# GIT_BRANCH=main
# GIT_SYNC_INTERVAL_SECONDS=300

# ── Paths ─────────────────────────────────────────────
VAULT_LOCAL_PATH=/data/vault

# ── Ports (host:container) ────────────────────────────
# WEB_PORT 는 실제 접속 진입점 (nginx). 사용자는 http://localhost:${WEB_PORT} 로 접속.
# BACKEND_PORT / FRONTEND_PORT 는 디버깅/직접 접근용 (nginx 우회).
WEB_PORT=80
WEB_HTTPS_PORT=443
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Optional: prebuilt app images (GHCR deploy) ──────────────────────
# Set these only when deploying with:
# docker compose -f docker-compose.yml -f docker-compose.ghcr.yml up -d
# BACKEND_IMAGE=ghcr.io/<owner>/obsidian-wiki-backend:latest
# FRONTEND_IMAGE=ghcr.io/<owner>/obsidian-wiki-frontend:latest
