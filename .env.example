# ── Database ──────────────────────────────────────────
POSTGRES_USER=obsidian
POSTGRES_PASSWORD=changeme
POSTGRES_DB=obsidian_wiki
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand
ADMIN_USERNAME=admin
# python -c "import bcrypt; print(bcrypt.hashpw(b'changeme', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$PLACEHOLDER

# ── Git Sync ──────────────────────────────────────────
GIT_REMOTE_URL=git@github.com:user/vault.git
GIT_BRANCH=main
GIT_SYNC_INTERVAL_SECONDS=300

# ── Paths ─────────────────────────────────────────────
VAULT_LOCAL_PATH=/data/vault

# ── Ports (host:container) ────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
